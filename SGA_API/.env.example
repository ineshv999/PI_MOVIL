# Copia este archivo como .env y cambia las credenciales antes de producción.
APP_NAME=SGA API
APP_ENV=development
API_V1_PREFIX=/api/v1
APP_DEBUG=true
API_EXPOSE_PORT=8001

POSTGRES_DB=sga
POSTGRES_USER=sga_user
POSTGRES_PASSWORD=cambia_esta_contrasena
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_EXPOSE_PORT=5433

# Solo para el contenedor de pgAdmin local.
PGADMIN_DEFAULT_EMAIL=admin@sga.local
PGADMIN_DEFAULT_PASSWORD=cambia_esta_contrasena
PGADMIN_EXPOSE_PORT=5050

# Lista separada por comas. En producción reemplaza por los dominios permitidos.
BACKEND_CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Genera valores distintos para producción. Nunca compartas este archivo .env.
JWT_SECRET_KEY=reemplaza_por_una_clave_larga_aleatoria_de_32_caracteres
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=reemplaza_por_una_clave_fernet_valida
EVIDENCE_DIRECTORY=uploads/evidencias
MAX_EVIDENCE_SIZE_MB=5
LOGIN_ATTEMPTS_PER_MINUTE=10
GRAFANA_ADMIN_PASSWORD=cambia_esta_contrasena
